# Database Connection (Supabase)
# DATABASE_URL represents the transaction pooler URL (port 6543) or direct url (port 5432)
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres"

# Supabase Public Keys
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_PUBLISHABLE_KEY"

# Headless WordPress CMS Endpoint
WORDPRESS_GRAPHQL_URL="https://YOUR_WORDPRESS_SITE/graphql"
REVALIDATION_SECRET="YOUR_REVALIDATION_SECRET_FOR_ISR"
CRON_SECRET="YOUR_CRON_SECRET"

# Upstash Redis (For Rate Limiting & Edge Caching)
UPSTASH_REDIS_REST_URL="https://YOUR_UPSTASH_REDIS_URL.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REDIS_TOKEN"

# Site URLs
NEXT_PUBLIC_SITE_URL="https://info-peru.vercel.app"

# Google AdSense auto ads
NEXT_PUBLIC_ADSENSE_ENABLED="true"
NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-2881186920154851"

# Admin CMS
# Generate a hash with: node -e "const crypto=require('crypto'); const p='CHANGE_ME'; const s=crypto.randomBytes(16).toString('hex'); console.log('scrypt:'+s+':'+crypto.scryptSync(p,s,64).toString('hex'))"
ADMIN_EMAIL="admin@claveperu.com"
ADMIN_PASSWORD_HASH="scrypt:CHANGE_ME_SALT:CHANGE_ME_HASH"
ADMIN_SESSION_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"

# Media Storage: local | supabase
MEDIA_STORAGE_PROVIDER="local"

# Supabase Storage (required when MEDIA_STORAGE_PROVIDER="supabase")
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_STORAGE_BUCKET="media"
# Optional custom public base URL. Defaults to Supabase public object URL.
SUPABASE_STORAGE_PUBLIC_URL=""
