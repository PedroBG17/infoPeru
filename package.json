    "@supabase/supabase-js": "^2.43.0",
    "@upstash/redis": "^1.31.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "isomorphic-dompurify": "^2.12.0",
    "lucide-react": "^0.379.0",
    "next": "^15.0.3",
    "react": "^19.0.0-rc-66a30550-20241107",
    "react-dom": "^19.0.0-rc-66a30550-20241107",
